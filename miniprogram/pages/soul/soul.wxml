<view class="container">
  <!-- 基础 3D 渲染层 -->
  <canvas type="webgl" id="webgl" style="width: 100%; height: 100vh; position: absolute; left: 0; top: 0; z-index: 0;" bindtouchstart="touchStart" bindtouchmove="touchMove" bindtouchend="touchEnd"></canvas>

  <view class="ui-layer">

    <!-- 底部导航栏 -->
    <view class="bottom-nav">
      <!-- 免费层 -->
      <view class="nav-item {{currentMode === 'NEBULA' ? 'active' : ''}}" bindtap="setTheme" data-mode="NEBULA">
        <view class="nav-dot" style="background: #3b82f6;"></view>
        <text class="nav-label">星云</text>
      </view>
      <view class="nav-item {{currentMode === 'FIREWORKS' ? 'active' : ''}}" bindtap="setTheme" data-mode="FIREWORKS">
        <view class="nav-dot" style="background: #f59e0b;"></view>
        <text class="nav-label">烟花</text>
      </view>
      <view class="nav-item {{currentMode === 'RAIN' ? 'active' : ''}}" bindtap="setTheme" data-mode="RAIN">
        <view class="nav-dot" style="background: #60a5fa;"></view>
        <text class="nav-label">雨滴</text>
      </view>
      <!-- 付费层 -->
      <view class="nav-item {{currentMode === 'FINGER_VORTEX' ? 'active' : ''}}" bindtap="setTheme" data-mode="FINGER_VORTEX">
        <view class="nav-dot" style="background: #a855f7;"></view>
        <text class="nav-label">黑洞</text>
      </view>
      <view class="nav-item {{currentMode === 'FLAME' ? 'active' : ''}}" bindtap="setTheme" data-mode="FLAME">
        <view class="nav-dot" style="background: linear-gradient(to top, #ef4444, #f59e0b);"></view>
        <text class="nav-label">火焰</text>
      </view>
      <view class="nav-item {{currentMode === 'KALEIDOSCOPE' ? 'active' : ''}}" bindtap="setTheme" data-mode="KALEIDOSCOPE">
        <view class="nav-dot" style="background: conic-gradient(#f43f5e, #f59e0b, #22c55e, #3b82f6, #a855f7, #f43f5e);"></view>
        <text class="nav-label">万花筒</text>
      </view>
      <view class="nav-item {{currentMode === 'LIGHT_PAINT' ? 'active' : ''}}" bindtap="setTheme" data-mode="LIGHT_PAINT">
        <view class="nav-dot" style="background: #f43f5e;"></view>
        <text class="nav-label">光绘</text>
      </view>
      <view class="nav-item {{currentMode === 'LASER' ? 'active' : ''}}" bindtap="setTheme" data-mode="LASER">
        <view class="nav-dot" style="background: #22d3ee;"></view>
        <text class="nav-label">激光</text>
      </view>
      <view class="nav-item {{currentMode === 'TIDAL' ? 'active' : ''}}" bindtap="setTheme" data-mode="TIDAL">
        <view class="nav-dot" style="background: #06b6d4;"></view>
        <text class="nav-label">潮汐</text>
      </view>
      <view class="nav-item {{currentMode === 'RIPPLE' ? 'active' : ''}}" bindtap="setTheme" data-mode="RIPPLE">
        <view class="nav-dot" style="background: #818cf8;"></view>
        <text class="nav-label">涟漪</text>
      </view>
      <!-- 调色板 -->
      <view class="nav-item palette-item {{showPalette ? 'active' : ''}}" bindtap="togglePalette">
        <view class="nav-dot" style="background: conic-gradient(red, yellow, lime, aqua, blue, magenta, red);"></view>
        <text class="nav-label">调色</text>
      </view>
    </view>

    <!-- 调色板面板 - hidden 保持 DOM -->
    <view class="palette-panel" hidden="{{!showPalette}}">
      <view class="palette-row">
        <view class="palette-label">色相</view>
        <slider class="palette-slider" min="0" max="360" value="{{customHue}}" activeColor="#60a5fa" block-size="14" bindchanging="onHueChange" bindchange="onHueChange" />
      </view>
      <view class="palette-row">
        <view class="palette-label">亮度</view>
        <slider class="palette-slider" min="10" max="100" value="{{customBright}}" activeColor="#60a5fa" block-size="14" bindchanging="onBrightChange" bindchange="onBrightChange" />
      </view>
      <view class="palette-row">
        <view class="palette-label">大小</view>
        <slider class="palette-slider" min="10" max="100" value="{{customSize}}" activeColor="#60a5fa" block-size="14" bindchanging="onSizeChange" bindchange="onSizeChange" />
      </view>
      <view class="palette-row">
        <view class="palette-label">数量</view>
        <slider class="palette-slider" min="10" max="100" value="{{customCount}}" activeColor="#60a5fa" block-size="14" bindchanging="onCountChange" bindchange="onCountChange" />
      </view>
    </view>
  </view>
</view>
