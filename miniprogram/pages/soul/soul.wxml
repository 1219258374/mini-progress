<view class="container">
  <!-- 基础 3D 渲染层 -->
  <canvas type="webgl" id="webgl" style="width: 100%; height: 100vh; position: absolute; left: 0; top: 0; z-index: 0;" bindtouchstart="touchStart" bindtouchmove="touchMove" bindtouchend="touchEnd"></canvas>

  <view class="ui-layer">
    <!-- Top Info -->
    <view class="top-info">
      <view class="glass-pill outfit tracking-widest text-blue-400">BLUEPRINT // LAB V3.3</view>
    </view>

    <!-- 侧边主题 -->
    <view class="theme-panel">
      <view class="theme-item {{currentMode === 'NEBULA' ? 'active' : ''}}" style="color: #3b82f6; background: #3b82f6;" bindtap="setTheme" data-mode="NEBULA"></view>
      <view class="theme-item {{currentMode === 'RIPPLE' ? 'active' : ''}}" style="color: #60a5fa; background: #60a5fa;" bindtap="setTheme" data-mode="RIPPLE"></view>
      <view class="theme-item {{currentMode === 'SOLAR' ? 'active' : ''}}" style="color: #06b6d4; background: #06b6d4;" bindtap="setTheme" data-mode="SOLAR"></view>
      <view class="theme-item {{currentMode === 'METEOR_SHOWER' ? 'active' : ''}}" style="color: #fbbf24; background: #fbbf24;" bindtap="setTheme" data-mode="METEOR_SHOWER"></view>
      <view class="theme-item {{currentMode === 'LIQUID_WAVE' ? 'active' : ''}}" style="color: #2dd4bf; background: #2dd4bf;" bindtap="setTheme" data-mode="LIQUID_WAVE"></view>
      <!-- 调色板按钮 -->
      <view class="theme-item palette-btn {{showPalette ? 'active' : ''}}" style="background: conic-gradient(red, yellow, lime, aqua, blue, magenta, red);" bindtap="togglePalette"></view>
    </view>

    <!-- 调色板面板 (底部) - 用 hidden 保持 DOM 不销毁, 避免滑块值重置 -->
    <view class="palette-panel" hidden="{{!showPalette}}">
      <view class="palette-row">
        <view class="palette-label">色相</view>
        <slider class="palette-slider" min="0" max="360" value="{{customHue}}" activeColor="#60a5fa" block-size="14" bindchanging="onHueChange" bindchange="onHueChange" />
      </view>
      <view class="palette-row">
        <view class="palette-label">亮度</view>
        <slider class="palette-slider" min="10" max="100" value="{{customBright}}" activeColor="#60a5fa" block-size="14" bindchanging="onBrightChange" bindchange="onBrightChange" />
      </view>
      <view class="palette-row">
        <view class="palette-label">大小</view>
        <slider class="palette-slider" min="10" max="100" value="{{customSize}}" activeColor="#60a5fa" block-size="14" bindchanging="onSizeChange" bindchange="onSizeChange" />
      </view>
    </view>
  </view>
</view>
