page {
  margin: 0;
  background-color: #00040a;
  color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  overflow: hidden;
  touch-action: none;
}

.container {
  position: relative;
  width: 100%;
  height: 100vh;
}

/* Typography styles */
.serif { font-family: serif; }
.outfit { font-family: sans-serif; }
.tracking-widest { letter-spacing: 0.1em; }

/* UI Layer */
.ui-layer {
  position: fixed;
  inset: 0;
  z-index: 20;
  pointer-events: none;
}

.top-info {
  position: fixed;
  top: 64rpx;
  left: 64rpx;
}

.glass-pill {
  background: rgba(30, 64, 175, 0.1);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(59, 130, 246, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  letter-spacing: 0.2em;
  color: #60a5fa;
  pointer-events: auto;
}

/* Theme Panel */
.theme-panel {
  position: fixed;
  right: 64rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 48rpx;
  pointer-events: auto;
  background: rgba(30, 58, 138, 0.1);
  padding: 48rpx 24rpx;
  border-radius: 64rpx;
  border: 1px solid rgba(59, 130, 246, 0.1);
}

.theme-item {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(59, 130, 246, 0.3);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.theme-item.active {
  transform: scale(1.4);
  border-color: white;
  box-shadow: 0 0 40rpx currentColor;
}

.theme-item.locked::after {
  content: '🔒';
  font-size: 16rpx;
  position: absolute;
  right: -30rpx;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.3;
}

.palette-btn {
  border: 4rpx solid rgba(255,255,255,0.4) !important;
}

/* Color Palette Panel */
.palette-panel {
  position: fixed;
  right: 140rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 300rpx;
  background: rgba(10, 25, 47, 0.85);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(59, 130, 246, 0.2);
  border-radius: 32rpx;
  padding: 32rpx 24rpx;
  pointer-events: auto;
  z-index: 30;
  animation: paletteIn 0.3s ease-out forwards;
}

@keyframes paletteIn {
  from { opacity: 0; transform: translateY(-50%) translateX(20rpx); }
  to { opacity: 1; transform: translateY(-50%) translateX(0); }
}

.palette-label {
  font-size: 18rpx;
  color: #60a5fa;
  letter-spacing: 0.15em;
  margin-bottom: 8rpx;
  font-family: sans-serif;
  text-transform: uppercase;
}

/* Scanner Corner */
.scanner-corner {
  position: fixed;
  bottom: 64rpx;
  left: 64rpx;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 240rpx;
}

.prog-text-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  width: 100%;
}

.prog-label {
  font-size: 14rpx;
  font-family: sans-serif;
  letter-spacing: 0.4em;
  color: #3b82f6;
  opacity: 0.6;
  text-transform: uppercase;
}

.prog-num {
  font-size: 16rpx;
  font-family: sans-serif;
  color: #60a5fa;
}

.energy-rail {
  width: 100%;
  height: 4rpx;
  background: rgba(59, 130, 246, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.energy-bar {
  height: 100%;
  background: #3b82f6;
  transition: width 0.3s;
  box-shadow: 0 0 30rpx #3b82f6;
}

/* Diagnostic Layer */
.diag-layer {
  position: fixed;
  bottom: 144rpx;
  left: 64rpx;
  z-index: 100;
  pointer-events: none;
}

.report-card-mini {
  width: 500rpx;
  background: rgba(10, 25, 47, 0.85);
  backdrop-filter: blur(50rpx);
  padding: 48rpx;
  border-radius: 48rpx;
  border: 1px solid rgba(59, 130, 246, 0.2);
  box-shadow: 0 40rpx 120rpx rgba(0,0,0,0.6);
  pointer-events: auto;
  animation: miniIn 0.6s cubic-bezier(0.2, 1, 0.3, 1) forwards;
}

@keyframes miniIn {
  from { opacity: 0; transform: translateX(-40rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.diag-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.res-id {
  font-size: 14rpx;
  font-family: sans-serif;
  color: #3b82f6;
}

.close-btn {
  font-size: 20rpx;
  color: #60a5fa;
  opacity: 0.4;
  padding: 10rpx;
}

.diag-title-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
}

.diag-icon { font-size: 48rpx; }
.diag-title { font-family: serif; font-size: 28rpx; font-weight: bold; color: #dbeafe; }

.diag-desc {
  font-size: 20rpx;
  color: rgba(191, 219, 254, 0.6);
  line-height: 1.6;
  font-family: serif;
  font-style: italic;
  border-left: 2rpx solid rgba(59, 130, 246, 0.4);
  padding-left: 24rpx;
  margin-bottom: 32rpx;
}

.btn-pay-mini {
  background: linear-gradient(135deg, #2563eb, #7c3aed);
  padding: 24rpx 32rpx;
  border-radius: 999rpx;
  font-weight: 800;
  font-size: 20rpx;
  letter-spacing: 0.1em;
  color: white;
  width: 100%;
  text-align: center;
  border: none;
  font-family: sans-serif;
  text-transform: uppercase;
}
