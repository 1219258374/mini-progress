page {
  margin: 0;
  background-color: #00040a;
  color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  overflow: hidden;
  touch-action: none;
}

.container {
  position: relative;
  width: 100%;
  height: 100vh;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(15, 30, 80, 0.25) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 80%, rgba(20, 10, 60, 0.2) 0%, transparent 45%),
    radial-gradient(ellipse at 50% 50%, rgba(8, 20, 50, 0.15) 0%, transparent 70%),
    #00040a;
}

/* Typography */
.serif { font-family: serif; }
.outfit { font-family: sans-serif; }
.tracking-widest { letter-spacing: 0.1em; }

/* UI Layer */
.ui-layer {
  position: fixed;
  inset: 0;
  z-index: 20;
  pointer-events: none;
}

.top-info {
  position: fixed;
  top: 64rpx;
  left: 64rpx;
}

.glass-pill {
  background: rgba(30, 64, 175, 0.1);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(59, 130, 246, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  letter-spacing: 0.2em;
  color: #60a5fa;
  pointer-events: auto;
}

/* ========== Bottom Navigation Bar ========== */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 16rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(5, 15, 35, 0.85);
  backdrop-filter: blur(30rpx);
  border-top: 1px solid rgba(59, 130, 246, 0.12);
  pointer-events: auto;
  z-index: 25;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  transition: all 0.3s ease;
  opacity: 0.5;
  transform: scale(0.9);
}

.nav-item.active {
  opacity: 1;
  transform: scale(1.05);
}

.nav-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.15);
  transition: all 0.3s ease;
}

.nav-item.active .nav-dot {
  width: 44rpx;
  height: 44rpx;
  border-color: rgba(255,255,255,0.6);
  box-shadow: 0 0 24rpx currentColor, 0 0 48rpx currentColor;
}

.nav-label {
  font-size: 18rpx;
  color: rgba(148, 163, 184, 0.7);
  font-family: sans-serif;
  letter-spacing: 0.05em;
}

.nav-item.active .nav-label {
  color: #e2e8f0;
  font-weight: 600;
}

/* ========== Palette Panel ========== */
.palette-panel {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  background: rgba(5, 15, 35, 0.92);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(59, 130, 246, 0.15);
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  pointer-events: auto;
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.palette-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.palette-slider {
  flex: 1;
}

.palette-label {
  font-size: 20rpx;
  color: #60a5fa;
  letter-spacing: 0.1em;
  font-family: sans-serif;
  min-width: 60rpx;
  flex-shrink: 0;
}
