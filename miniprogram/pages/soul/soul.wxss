page {
  margin: 0;
  background-color: #00040a;
  color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  overflow: hidden;
  touch-action: none;
}

.container {
  position: relative;
  width: 100%;
  height: 100vh;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(15, 30, 80, 0.25) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 80%, rgba(20, 10, 60, 0.2) 0%, transparent 45%),
    radial-gradient(ellipse at 50% 50%, rgba(8, 20, 50, 0.15) 0%, transparent 70%),
    #00040a;
}

/* Typography */
.serif { font-family: serif; }
.outfit { font-family: sans-serif; }
.tracking-widest { letter-spacing: 0.1em; }

/* UI Layer */
.ui-layer {
  position: fixed;
  inset: 0;
  z-index: 20;
  pointer-events: none;
}

.top-info {
  position: fixed;
  top: 64rpx;
  left: 64rpx;
}

.glass-pill {
  background: rgba(30, 64, 175, 0.1);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(59, 130, 246, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  letter-spacing: 0.2em;
  color: #60a5fa;
  pointer-events: auto;
}

/* ========== Bottom Navigation Bar ========== */
.ui-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 10;
}

/* ========== Top Right Settings Button ========== */
.settings-btn {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 20rpx);
  right: 32rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(20rpx);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: auto;
  transition: all 0.3s ease;
  z-index: 40;
}

.settings-btn:active {
  transform: scale(0.9);
  background: rgba(30, 41, 59, 0.8);
}

.settings-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1;
}

/* ========== Magic Rack (Floating Effects Dragger) ========== */
.rack-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 20;
}

.rack-view {
  pointer-events: auto;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(255, 255, 255, 0.15);
  box-shadow: 0 16rpx 48rpx rgba(0,0,0,0.6);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.rack-view.collapsed {
  width: auto;
  height: auto;
  border-radius: 999rpx;
}

.rack-view.expanded {
  width: 340rpx;
  border-radius: 40rpx;
  padding-bottom: 24rpx;
}

.rack-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 32rpx;
  gap: 16rpx;
}

.rack-icon {
  font-size: 32rpx;
}

.rack-title {
  font-size: 26rpx;
  color: #f8fafc;
  font-weight: 500;
  letter-spacing: 0.1em;
  white-space: nowrap;
}

.rack-arrow {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: auto;
}

.rack-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx 16rpx;
  padding: 12rpx 24rpx 0;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 0;
  position: relative;
  transition: all 0.3s ease;
  opacity: 0.6;
}

.nav-item.active {
  opacity: 1;
  transform: translateY(-4rpx);
}

.nav-label {
  font-size: 24rpx;
  color: #f8fafc;
  font-family: sans-serif;
  letter-spacing: 0.05em;
  font-weight: 400;
  transition: all 0.3s ease;
}

.nav-item.active .nav-label {
  font-weight: 600;
  text-shadow: 0 0 16rpx var(--theme-color), 0 0 4rpx rgba(255,255,255,0.8);
}

/* 底部发光指示条 (Glowing Underscore) */
.nav-item::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 4rpx;
  background: var(--theme-color);
  border-radius: 4rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 12rpx var(--theme-color);
  opacity: 0;
}

.nav-item.active::after {
  width: 80%;
  opacity: 1;
}

/* ========== Palette Panel ========== */
.palette-panel {
  position: fixed;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  left: 32rpx;
  right: 32rpx;
  background: rgba(5, 15, 35, 0.92);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(59, 130, 246, 0.15);
  border-radius: 28rpx;
  padding: 24rpx 28rpx;
  pointer-events: auto;
  z-index: 30;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.palette-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.palette-slider {
  flex: 1;
}

.palette-label {
  font-size: 20rpx;
  color: #60a5fa;
  letter-spacing: 0.1em;
  font-family: sans-serif;
  min-width: 60rpx;
  flex-shrink: 0;
}
