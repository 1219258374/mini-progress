page {
  margin: 0;
  background-color: #00040a;
  color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  overflow: hidden;
  touch-action: none;
}

.container {
  position: relative;
  width: 100%;
  height: 100vh;
  background:
    radial-gradient(ellipse at 30% 20%, rgba(15, 30, 80, 0.25) 0%, transparent 50%),
    radial-gradient(ellipse at 70% 80%, rgba(20, 10, 60, 0.2) 0%, transparent 45%),
    radial-gradient(ellipse at 50% 50%, rgba(8, 20, 50, 0.15) 0%, transparent 70%),
    #00040a;
}

/* Typography */
.serif { font-family: serif; }
.outfit { font-family: sans-serif; }
.tracking-widest { letter-spacing: 0.1em; }

/* UI Layer */
.ui-layer {
  position: fixed;
  inset: 0;
  z-index: 20;
  pointer-events: none;
}

.top-info {
  position: fixed;
  top: 64rpx;
  left: 64rpx;
}

.glass-pill {
  background: rgba(30, 64, 175, 0.1);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(59, 130, 246, 0.2);
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  letter-spacing: 0.2em;
  color: #60a5fa;
  pointer-events: auto;
}

/* ========== Bottom Navigation Bar ========== */
.ui-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  pointer-events: none;
  z-index: 10;
}

/* ========== Right Settings Drawer ========== */
.settings-drawer {
  position: absolute;
  bottom: 60rpx; /* Anchored near bottom right */
  right: 0;
  display: flex;
  align-items: stretch;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-right: none;
  border-radius: 40rpx 0 0 40rpx;
  box-shadow: -16rpx 0 48rpx rgba(0,0,0,0.6);
  z-index: 40;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: auto;
}

.settings-drawer.collapsed {
  transform: translateX(100%);
}

.settings-drawer.expanded {
  transform: translateX(0);
}

.settings-handle {
  width: 60rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: absolute;
  left: -60rpx;
  bottom: 60rpx; /* Positioned near the bottom of the drawer */
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-right: none;
  border-radius: 24rpx 0 0 24rpx;
  box-shadow: -8rpx 0 24rpx rgba(0,0,0,0.4);
}

.settings-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1;
}

/* ========== Magic Side Drawer (特效侧边抽屉) ========== */
.side-drawer {
  position: absolute;
  top: 40rpx; /* Anchored near top left */
  left: 0;
  display: flex;
  align-items: stretch;
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-left: none;
  border-radius: 0 40rpx 40rpx 0;
  box-shadow: 16rpx 0 48rpx rgba(0,0,0,0.6);
  z-index: 20;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  pointer-events: auto;
}

.side-drawer.collapsed {
  transform: translateX(-100%);
}

.side-drawer.expanded {
  transform: translateX(0);
}

/* 抽屉边缘的把手 */
.drawer-handle {
  width: 60rpx;
  height: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: absolute;
  right: -60rpx;
  top: 60rpx; /* Positioned near top of the drawer */
  background: rgba(15, 23, 42, 0.7);
  backdrop-filter: blur(30rpx);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-left: none;
  border-radius: 0 24rpx 24rpx 0;
  box-shadow: 8rpx 0 24rpx rgba(0,0,0,0.4);
}

.handle-icon {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.handle-dots {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  opacity: 0.5;
}

.handle-dots .dot {
  width: 6rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 50%;
}

/* 展开后的内容区 */
.drawer-content {
  width: 180rpx;
  max-height: 60vh;
}

/* 隐藏 scroll-view 滚动条 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
  color: transparent;
}

.drawer-grid {
  display: flex;
  flex-direction: column;
  padding: 32rpx 0;
  gap: 24rpx;
}

.nav-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  position: relative;
  transition: all 0.3s ease;
  opacity: 0.6;
}

.nav-item.active {
  opacity: 1;
  transform: translateX(8rpx);
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
  transition: all 0.3s ease;
  filter: grayscale(100%);
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.nav-item.active .nav-icon {
  filter: grayscale(0%);
  transform: scale(1.1);
}

.nav-label {
  font-size: 26rpx;
  color: #f8fafc;
  font-family: sans-serif;
  letter-spacing: 0.05em;
  font-weight: 400;
  transition: all 0.3s ease;
}

.nav-item.active .nav-label {
  font-weight: 600;
  text-shadow: 0 0 16rpx var(--theme-color), 0 0 4rpx rgba(255,255,255,0.8);
}

/* 左侧边条指示器 (Glowing Left Border) */
.nav-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 0;
  background: var(--theme-color);
  border-radius: 6rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 12rpx var(--theme-color);
  opacity: 0;
}

.nav-item.active::before {
  height: 60%;
  opacity: 1;
}

/* ========== Palette Panel Content ========== */
.palette-panel {
  width: 440rpx;
  padding: 32rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-sizing: border-box;
}

.palette-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.palette-slider {
  flex: 1;
}

.palette-label {
  font-size: 20rpx;
  color: #60a5fa;
  letter-spacing: 0.1em;
  font-family: sans-serif;
  min-width: 60rpx;
  flex-shrink: 0;
}
