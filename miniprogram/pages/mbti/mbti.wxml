<view class="container">
  <!-- 基础 3D 渲染层 -->
  <canvas type="webgl" id="webgl" style="width: 100%; height: 100vh; position: absolute; z-index: -1;" bindtouchstart="touchStart" bindtouchmove="touchMove" bindtouchend="touchEnd"></canvas>

  <!-- Step 0: 激活引擎 -->
  <view id="audio-gate" class="audio-gate" wx:if="{{step === 0}}">
    <view class="glass p-12 text-center">
      <view class="title-text text-indigo-400">YOROZUYA LAB</view>
      <view class="subtitle uppercase text-slate-500">Initialize Bio-Digital Engine</view>
      <button class="synthesis-btn w-full" bindtap="enterLab">进入实验室</button>
      <view class="note">⚠️ 原版 Tone.js 暂不可在小程序使用，此按钮用于进入交互界面。</view>
    </view>
  </view>

  <!-- 加载过程 -->
  <view id="loader" class="loader" wx:if="{{step === 1}}">
    <view class="loader-circle border-white-5">
      <view class="loader-symbol animate-pulse">🧬</view>
      <!-- 简单的进度条替代复杂的 SVG stroke 动画 -->
      <view class="progress-bar-container">
          <view class="progress-bar" style="width: {{loadProgress}}%"></view>
      </view>
    </view>
    <view class="loader-msg text-indigo-400">{{loadMessage}}</view>
  </view>

  <view class="main-content" wx:if="{{step === 2 || step === 3}}">
    <view class="header opacity-30">
      <view class="header-text text-indigo-400">Personality Evolution // Ver. 8.0</view>
      <view class="header-line bg-white-20"></view>
    </view>

    <!-- 配置页 -->
    <view id="page-config" class="page-config {{step === 2 ? 'active' : ''}}">
      <view class="title-section">
        <view class="text-4xl serif font-bold">灵魂标本全量库</view>
        <view class="text-[9px] outfit uppercase text-slate-500 uppercase-tracking">16-Personalities Comprehensive Synthesis</view>
      </view>

      <view class="glass scroll-box w-full max-w-md">
        <!-- MBTI Matrix -->
        <view class="space-y-4">
          <view class="section-title text-indigo-500">01. Choose Identity Gene</view>
          
          <view class="grid-4 gap-2">
            <view class="chip {{selectedMBTI === 'INTJ' ? 'active analyst' : ''}}" bindtap="setMBTI" data-m="INTJ" data-g="analyst">INTJ</view>
            <view class="chip {{selectedMBTI === 'INTP' ? 'active analyst' : ''}}" bindtap="setMBTI" data-m="INTP" data-g="analyst">INTP</view>
            <view class="chip {{selectedMBTI === 'ENTJ' ? 'active analyst' : ''}}" bindtap="setMBTI" data-m="ENTJ" data-g="analyst">ENTJ</view>
            <view class="chip {{selectedMBTI === 'ENTP' ? 'active analyst' : ''}}" bindtap="setMBTI" data-m="ENTP" data-g="analyst">ENTP</view>
          </view>
          <view class="grid-4 gap-2 mt-2">
            <view class="chip {{selectedMBTI === 'INFJ' ? 'active diplomat' : ''}}" bindtap="setMBTI" data-m="INFJ" data-g="diplomat">INFJ</view>
            <view class="chip {{selectedMBTI === 'INFP' ? 'active diplomat' : ''}}" bindtap="setMBTI" data-m="INFP" data-g="diplomat">INFP</view>
            <view class="chip {{selectedMBTI === 'ENFJ' ? 'active diplomat' : ''}}" bindtap="setMBTI" data-m="ENFJ" data-g="diplomat">ENFJ</view>
            <view class="chip {{selectedMBTI === 'ENFP' ? 'active diplomat' : ''}}" bindtap="setMBTI" data-m="ENFP" data-g="diplomat">ENFP</view>
          </view>
          <view class="grid-4 gap-2 mt-2">
            <view class="chip {{selectedMBTI === 'ISTJ' ? 'active sentinel' : ''}}" bindtap="setMBTI" data-m="ISTJ" data-g="sentinel">ISTJ</view>
            <view class="chip {{selectedMBTI === 'ISFJ' ? 'active sentinel' : ''}}" bindtap="setMBTI" data-m="ISFJ" data-g="sentinel">ISFJ</view>
            <view class="chip {{selectedMBTI === 'ESTJ' ? 'active sentinel' : ''}}" bindtap="setMBTI" data-m="ESTJ" data-g="sentinel">ESTJ</view>
            <view class="chip {{selectedMBTI === 'ESFJ' ? 'active sentinel' : ''}}" bindtap="setMBTI" data-m="ESFJ" data-g="sentinel">ESFJ</view>
          </view>
          <view class="grid-4 gap-2 mt-2">
            <view class="chip {{selectedMBTI === 'ISTP' ? 'active explorer' : ''}}" bindtap="setMBTI" data-m="ISTP" data-g="explorer">ISTP</view>
            <view class="chip {{selectedMBTI === 'ISFP' ? 'active explorer' : ''}}" bindtap="setMBTI" data-m="ISFP" data-g="explorer">ISFP</view>
            <view class="chip {{selectedMBTI === 'ESTP' ? 'active explorer' : ''}}" bindtap="setMBTI" data-m="ESTP" data-g="explorer">ESTP</view>
            <view class="chip {{selectedMBTI === 'ESFP' ? 'active explorer' : ''}}" bindtap="setMBTI" data-m="ESFP" data-g="explorer">ESFP</view>
          </view>
        </view>

        <!-- Mood Vibe -->
        <view class="space-y-4 pt-4 border-t-white-5 mt-4">
          <view class="section-title text-sky-500">02. Choose Emotional Vibe</view>
          <view class="grid-4 gap-3">
            <view class="chip mood {{selectedVibe === 'FLOW' ? 'active' : ''}}" bindtap="setVibe" data-v="FLOW">平静</view>
            <view class="chip mood {{selectedVibe === 'GLITCH' ? 'active' : ''}}" bindtap="setVibe" data-v="GLITCH">焦虑</view>
            <view class="chip mood {{selectedVibe === 'SPARK' ? 'active' : ''}}" bindtap="setVibe" data-v="SPARK">兴奋</view>
            <view class="chip mood {{selectedVibe === 'VOID' ? 'active' : ''}}" bindtap="setVibe" data-v="VOID">空虚</view>
          </view>
        </view>
      </view>

      <button class="synthesis-btn w-full max-w-md mt-6" bindtap="startSynthesis">
        融合数字标本
      </button>
    </view>

    <!-- 结果页 -->
    <view id="page-result" class="page-result {{step === 3 ? 'active' : ''}}">
      <view class="glass p-10 w-full text-center relative border-t-2-indigo">
        <view class="absolute-id">
          <view class="text-[7px] outfit uppercase text-slate-500 font-bold">Unique Asset ID</view>
          <view class="text-xs outfit font-black text-indigo-400">{{resId}}</view>
        </view>

        <view class="text-left space-y-1 mt-8">
          <view class="text-[10px] outfit font-black tracking-widest text-indigo-500 uppercase">{{selectedMBTI}} // {{selectedVibe}}</view>
          <view class="text-4xl serif font-bold">{{resData.n}}</view>
        </view>

        <view class="res-icon-wrapper">
          <view class="res-icon-container bg-white-03 border-white-10">
            <view class="res-icon text-7xl icon-vibe-{{selectedVibe}}">{{resData.i}}</view>
          </view>
        </view>

        <view class="text-left mt-6">
          <view class="res-text serif italic border-l-2-indigo pl-5">
            {{resData.text}}
          </view>
          <view class="flex justify-between items-end pt-6 opacity-20 text-[7px] outfit font-bold uppercase tracking-widest">
            <text>Verified Batch\nYRZ-GEN-2026</text>
            <text class="text-right">Workshop Auth\nSpecimen Secure</text>
          </view>
        </view>
      </view>
      
      <view class="mt-8 flex space-x-4 w-full justify-between gap-4">
        <button class="btn-secondary flex-1" bindtap="restart">重新实验</button>
        <button class="synthesis-btn flex-1 text-[10px]" bindtap="saveSpecimen">保存标本名片</button>
      </view>
    </view>

    <view class="footer pb-6 text-center w-full">
      <text class="text-[9px] outfit text-slate-700 uppercase-tracking font-black">Architect & Curator Synergy</text>
    </view>
  </view>
</view>
