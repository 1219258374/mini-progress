/* home.wxss */
page {
  background-color: #020617; /* Dark slate */
  color: #f8fafc;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  height: 100vh;
  overflow: hidden;
}

.container {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-sizing: border-box;
}

/* Background Effects */
.bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  z-index: 1;
  opacity: 0.5;
}

.orb-1 {
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, #6366f1 0%, rgba(99, 102, 241, 0) 70%);
  top: -100rpx;
  left: -100rpx;
  animation: float1 10s ease-in-out infinite alternate;
}

.orb-2 {
  width: 500rpx;
  height: 500rpx;
  background: radial-gradient(circle, #3b82f6 0%, rgba(59, 130, 246, 0) 70%);
  bottom: -50rpx;
  right: -100rpx;
  animation: float2 12s ease-in-out infinite alternate;
}

.bg-noise {
  position: absolute;
  inset: 0;
  z-index: 2;
  opacity: 0.03;
  pointer-events: none;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
}

/* Animations */
@keyframes float1 {
  0% { transform: translate(0, 0); }
  100% { transform: translate(50rpx, 50rpx); }
}

@keyframes float2 {
  0% { transform: translate(0, 0); }
  100% { transform: translate(-40rpx, -60rpx); }
}

/* Header */
.header {
  z-index: 10;
  text-align: center;
  margin-bottom: 80rpx;
  animation: fadeInDown 1s ease forwards;
}

.logo-text {
  font-size: 48rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
  color: #818cf8; /* Indigo */
  text-transform: uppercase;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #94a3b8;
  letter-spacing: 4rpx;
  text-transform: uppercase;
}

/* Cards */
.cards-wrapper {
  z-index: 10;
  width: 100%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.glass-card {
  position: relative;
  background: rgba(15, 23, 42, 0.4);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  overflow: hidden;
  animation: fadeInUp 1s ease forwards;
  opacity: 0;
}

.card-mbti {
  animation-delay: 0.2s;
}

.card-soul {
  animation-delay: 0.4s;
}

/* Card Hover/Tap Effect */
.card-hover {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.1);
  border-color: rgba(255, 255, 255, 0.2);
}

.card-icon {
  font-size: 64rpx;
  margin-right: 32rpx;
  background: rgba(255, 255, 255, 0.05);
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.card-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.card-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.glass-card:active .card-arrow {
  transform: translateX(10rpx);
  color: #ffffff;
}

/* Footer */
.footer {
  position: absolute;
  bottom: 60rpx;
  z-index: 10;
  font-size: 18rpx;
  color: #475569;
  letter-spacing: 6rpx;
  text-transform: uppercase;
  font-weight: 700;
  animation: fadeIn 2s ease forwards 1s;
  opacity: 0;
}

/* Keyframes */
@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(40rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
